# ===== Embedding =====
# Model sinh cả dense và sparse trong 1 forward pass
BGE_MODEL_NAME=BAAI/bge-m3
EMBED_BATCH_SIZE=32

# ===== Qdrant =====
QDRANT_URL=http://qdrant:6333
VECTOR_DIM=1024
VECTOR_NAME=dense
SPARSE_VECTOR_NAME=sparse

# ===== Chunking =====
# Ngưỡng cắt semantic chunk (percentile)
# Cao = ít điểm cắt = chunk to hơn
SEMANTIC_THRESHOLD_TYPE=percentile
SEMANTIC_THRESHOLD_AMOUNT=95

# Trần kích thước parent — chặn context dài không kiểm soát
MAX_PARENT_SIZE=2000

# Đơn vị được embed và search
CHILD_CHUNK_SIZE=400
CHILD_CHUNK_OVERLAP=50

# ===== Paths =====
UPLOAD_DIR=/data/uploads
